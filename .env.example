# Variables de Entorno - BPAE
# Copiar este archivo a .env y completar los valores

# App
APP_NAME=BPAE API
APP_ENV=development
DEBUG=true

# APIs Externas (Obtener de sus respectivos dashboards)
MINIMAX_API_KEY=tu_api_key_aqui
TAVILY_API_KEY=tu_api_key_aqui

# Supabase (Obtener de Project Settings > API)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_service_role_key_aqui
